# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SITE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
CRON_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/discord/callback"

# File upload provider
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="spot-images"
R2_PUBLIC_BASE_URL=""

# Global offline switch.
# Leave empty for normal operation. Set to a message to serve a 503 offline page
# for all app, API, and auth routes before Supabase is contacted.
XIVSPOTS_OFFLINE_MESSAGE=""

# Discord auth access controls
# Set to "false" to prevent first-time Discord users from creating app profiles.
XIVSPOTS_ALLOW_DISCORD_REGISTRATION="true"
# Set to "false" to allow only moderators and admins to sign in with Discord.
XIVSPOTS_ALLOW_NON_STAFF_DISCORD_LOGIN="true"

# Submission limits
XIVSPOTS_MAX_DRAFTS_PER_USER="5"
XIVSPOTS_MAX_PENDING_SPOTS_PER_USER="10"

# Discord notifications
XIVSPOTS_REVIEW_DISCORD_WEBHOOK_URL=""
